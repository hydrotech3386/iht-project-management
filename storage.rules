rules_version = '2';

// Project Management app — all files live under pm/ so they stay separate
// from anything else in the shared iht-project-schedule project.
service firebase.storage {
  match /b/{bucket}/o {
    // {allPaths=**} so nested folders (e.g. photos/) are covered, not just
    // files sitting directly under the project
    match /pm/projects/{projectId}/{allPaths=**} {
      // Signed-in users can read. Note: files opened from the app use a
      // tokenised download URL, which works for ?view read-only links too.
      allow read: if request.auth != null;

      // Uploads: signed in, max 25MB, PDFs and images only.
      allow create, update: if request.auth != null
                   && request.resource.size < 25 * 1024 * 1024
                   && (request.resource.contentType.matches('application/pdf')
                       || request.resource.contentType.matches('image/.*'));

      // Deletes: `request.resource` is null on a delete request, so the
      // size/contentType checks above can never apply here — a delete rule
      // needs its own clause, or every delete silently 403s and the storage
      // object is orphaned even though the DB record is removed.
      allow delete: if request.auth != null;
    }

    // Everything outside pm/ is denied to this app.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
